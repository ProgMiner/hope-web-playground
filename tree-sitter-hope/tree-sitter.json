{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "hope",
      "camelcase": "Hope",
      "title": "Hope",
      "scope": "source.hope",
      "file-types": ["hope"],
      "injection-regex": "^hope$",
      "class-name": "TreeSitterHope",
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Hope grammar for tree-sitter",
    "authors": [
      {
        "name": "Vasily Fedorov",
        "email": "vasek.fedorov@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-hope"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": true,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
